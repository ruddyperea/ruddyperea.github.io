<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ruddy Perea | Página Personal</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', sans-serif;
        }

        body {
            background: #f4f7fc;
            color: #333;
        }

        header {
            background: linear-gradient(135deg, #003366, #0059b3);
            color: white;
            text-align: center;
            padding: 60px 20px;
        }

        header h1 {
            font-size: 3rem;
            margin-bottom: 10px;
        }

        header p {
            font-size: 1.2rem;
        }

        nav {
            background: white;
            padding: 15px;
            text-align: center;
            box-shadow: 0 2px 8px rgba(0, 0, 0, .1);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        nav a {
            text-decoration: none;
            color: #003366;
            margin: 0 15px;
            font-weight: bold;
            transition: .3s;
        }

        nav a:hover {
            color: #0059b3;
        }

        .container {
            width: 90%;
            max-width: 1100px;
            margin: auto;
        }

        section {
            background: white;
            margin: 30px 0;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, .08);
        }

        h2 {
            color: #003366;
            margin-bottom: 20px;
            border-left: 5px solid #0059b3;
            padding-left: 10px;
        }

        .sobre-mi p {
            font-size: 1.05rem;
            line-height: 1.8;
        }

        .skills {
            margin-top: 20px;
        }

        .skills span {
            display: inline-block;
            background: #e8f0ff;
            color: #003366;
            padding: 8px 15px;
            border-radius: 20px;
            margin: 5px;
            font-weight: 500;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        table th {
            background: #003366;
            color: white;
            padding: 12px;
        }

        table td {
            padding: 12px;
            border-bottom: 1px solid #ddd;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        .card {
            background: #fafafa;
            border-radius: 12px;
            padding: 20px;
            border-top: 4px solid #0059b3;
            transition: .3s;
        }

        .card:hover {
            transform: translateY(-5px);
        }

        .card h3 {
            color: #003366;
            margin-bottom: 10px;
        }

        .card a {
            color: #0059b3;
            text-decoration: none;
            font-weight: bold;
        }

        .card a:hover {
            text-decoration: underline;
        }

        .companeros ul {
            list-style: none;
        }

        .companeros li {
            margin: 15px 0;
        }

        .companeros a {
            text-decoration: none;
            color: #0059b3;
            font-weight: bold;
            font-size: 1.05rem;
        }

        .companeros a:hover {
            text-decoration: underline;
        }

        .contacto p {
            margin: 12px 0;
        }

        .contacto a {
            color: #0059b3;
            text-decoration: none;
            font-weight: bold;
        }

        .contacto a:hover {
            text-decoration: underline;
        }

        footer {
            background: #003366;
            color: white;
            text-align: center;
            padding: 20px;
            margin-top: 40px;
        }

        @media(max-width:768px) {
            header h1 {
                font-size: 2rem;
            }

            nav a {
                display: block;
                margin: 10px 0;
            }

            table {
                font-size: 0.9rem;
            }
        }
    </style>
</head>

